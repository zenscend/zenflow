# ─── Database ──────────────────────────────────────────────────────────────────
# Pooler URL (Transaction mode) — used by the app at runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL — used by prisma migrate / prisma db push (bypasses pooler)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""   # safe to expose to the browser
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""              # server-side only — never expose to the client

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="https://your-app-domain.com"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app-domain.com"
NEXT_PUBLIC_APP_NAME="ZenFlow"
NEXT_PUBLIC_VAT_RATE="0.15"
