generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum sa_province {
  EASTERN_CAPE
  FREE_STATE
  GAUTENG
  KWAZULU_NATAL
  LIMPOPO
  MPUMALANGA
  NORTH_WEST
  NORTHERN_CAPE
  WESTERN_CAPE
}

enum bank_account_type {
  CHEQUE
  SAVINGS
  TRANSMISSION
}

enum global_role {
  USER
  SUPER_ADMIN
}

enum org_role {
  OWNER
  ADMIN
  MEMBER
}

enum customer_type {
  BUSINESS
  INDIVIDUAL
}

enum product_type {
  SERVICE
  PHYSICAL
}

enum quote_status {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum invoice_status {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ─── ORGANISATION ─────────────────────────────────────────────────────────────

model organisation {
  id             String  @id @default(uuid())
  name           String
  trading_name   String?
  company_reg_no String?
  vat_number     String?
  logo_url       String?

  address_line_1 String?
  address_line_2 String?
  city           String?
  province       sa_province?
  postal_code    String?
  country        String       @default("South Africa")

  phone   String?
  email   String?
  website String?

  bank_name         String?
  bank_account_name String?
  bank_account_no   String?
  bank_branch_code  String?
  bank_account_type bank_account_type?

  quote_prefix               String @default("QUO")
  invoice_prefix             String @default("INV")
  next_quote_no              Int    @default(1)
  next_invoice_no            Int    @default(1)
  default_payment_terms_days Int    @default(30)
  default_quote_valid_days   Int    @default(30)
  default_notes              String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users                 user_organisation[]
  taxes                 tax[]
  customers             customer[]
  contact_organisations contact_organisation[]
  products              product[]
  quotes                quote[]
  invoices              invoice[]
}

// ─── TAX ──────────────────────────────────────────────────────────────────────

model tax {
  id              String  @id @default(uuid())
  organisation_id String
  name            String  // "VAT", "Zero-rated", "Exempt"
  rate            Decimal @db.Decimal(6, 4) // 0.1500
  is_active       Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)
  line_items   line_item[]
  products     product[]

  @@index([organisation_id, is_active])
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model user {
  id             String      @id @default(uuid())
  first_name     String?
  last_name      String?
  email          String      @unique
  password_hash  String
  email_verified DateTime?
  image          String?
  role           global_role @default(USER)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisations user_organisation[]
}

model user_organisation {
  id              String   @id @default(uuid())
  user_id         String
  organisation_id String
  role            org_role @default(MEMBER)
  joined_at       DateTime @default(now())

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         user         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)

  @@unique([user_id, organisation_id])
  @@index([organisation_id])
}

// ─── CONTACTS (CRM) ───────────────────────────────────────────────────────────
// A contact is a natural person who may be linked to one or many organisations
// via the contact_organisation junction table.

model contact {
  id         String  @id @default(uuid())
  first_name String
  last_name  String
  email      String?
  phone      String?
  id_number  String?
  notes      String?
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisations contact_organisation[]
  customers     customer[]
}

model contact_organisation {
  id              String   @id @default(uuid())
  contact_id      String
  organisation_id String
  created_at      DateTime @default(now())

  contact      contact      @relation(fields: [contact_id],      references: [id], onDelete: Cascade)
  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)

  @@unique([contact_id, organisation_id])
  @@index([organisation_id])
}

// ─── CUSTOMERS ────────────────────────────────────────────────────────────────

model customer {
  id              String        @id @default(uuid())
  organisation_id String
  type            customer_type @default(BUSINESS)
  contact_id      String?       // optional link to a contact record

  company_name   String?
  trading_name   String?
  company_reg_no String?
  vat_number     String?

  display_name String

  email           String?
  phone           String?
  alternate_phone String?

  address_line_1 String?
  address_line_2 String?
  city           String?
  province       sa_province?
  postal_code    String?
  country        String       @default("South Africa")

  billing_address_line_1 String?
  billing_address_line_2 String?
  billing_city           String?
  billing_province       sa_province?
  billing_postal_code    String?

  notes     String?
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)
  contact      contact?      @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  quotes       quote[]
  invoices     invoice[]

  @@index([organisation_id])
  @@index([organisation_id, is_active])
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model product {
  id              String       @id @default(uuid())
  organisation_id String
  type            product_type @default(SERVICE)
  name            String
  description     String?
  unit_price      Decimal      @db.Decimal(15, 2)
  unit_type       String       @default("item")
  default_tax_id  String?      // null = not taxable by default
  is_active       Boolean      @default(true)
  sku             String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisation      organisation        @relation(fields: [organisation_id], references: [id], onDelete: Cascade)
  default_tax       tax?                @relation(fields: [default_tax_id], references: [id], onDelete: SetNull)
  product_line_items product_line_item[]

  @@index([organisation_id])
  @@index([organisation_id, is_active])
}

// ─── QUOTES ───────────────────────────────────────────────────────────────────

model quote {
  id              String       @id @default(uuid())
  organisation_id String
  customer_id     String
  quote_number    String
  status          quote_status @default(DRAFT)
  title           String?
  notes           String?
  internal_notes  String?

  issue_date  DateTime @default(now())
  expiry_date DateTime

  subtotal   Decimal @db.Decimal(15, 2) @default(0)
  vat_amount Decimal @db.Decimal(15, 2) @default(0)
  total      Decimal @db.Decimal(15, 2) @default(0)

  converted_to_invoice_id String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)
  customer     customer     @relation(fields: [customer_id], references: [id])
  invoice      invoice?     @relation(fields: [converted_to_invoice_id], references: [id])
  // Line items loaded via: prisma.line_item.findMany({ where: { source: "quote", source_id: id } })

  @@unique([organisation_id, quote_number])
  @@index([organisation_id, status])
  @@index([organisation_id, customer_id])
}

// ─── INVOICES ─────────────────────────────────────────────────────────────────

model invoice {
  id               String         @id @default(uuid())
  organisation_id  String
  customer_id      String
  invoice_number   String
  quote_id         String?        // set when converted from a quote
  status           invoice_status @default(DRAFT)
  title            String?
  notes            String?
  internal_notes   String?
  payment_reference String?

  issue_date DateTime @default(now())
  due_date   DateTime

  paid_at        DateTime?
  paid_amount    Decimal?  @db.Decimal(15, 2)
  payment_method String?

  subtotal   Decimal @db.Decimal(15, 2) @default(0)
  vat_amount Decimal @db.Decimal(15, 2) @default(0)
  total      Decimal @db.Decimal(15, 2) @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organisation organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)
  customer     customer     @relation(fields: [customer_id], references: [id])
  quote        quote?
  // Line items loaded via: prisma.line_item.findMany({ where: { source: "invoice", source_id: id } })

  @@unique([organisation_id, invoice_number])
  @@index([organisation_id, status])
  @@index([organisation_id, due_date])
  @@index([organisation_id, customer_id])
}

// ─── LINE ITEMS ───────────────────────────────────────────────────────────────
// source: "quote" | "invoice"  (enforced by CHECK constraint in migration)
// source_id: id of the parent quote or invoice (no DB FK — manual cascade)
// type: 1 = product (catalog), 2 = custom (free-form)
//
// Sub-tables carry the type-specific fields:
//   type=1 → product_line_item (product_id NOT NULL, description snapshot, unit_price, unit_type)
//   type=2 → custom_line_item  (description, unit_price, unit_type)
//
// tax_id is NOT NULL — use the seeded "Exempt" tax (rate=0) for untaxed lines.

model line_item {
  id        String @id @default(uuid())
  source    String // "quote" | "invoice"
  source_id String // parent id
  tax_id    String // NOT NULL — select "Exempt" for untaxed lines
  type      Int    // 1=product, 2=custom

  quantity   Decimal @db.Decimal(10, 3)
  discount   Decimal @db.Decimal(5, 2)  @default(0)
  line_total Decimal @db.Decimal(15, 2)
  tax_amount Decimal @db.Decimal(15, 2) @default(0)
  sort_order Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tax              tax               @relation(fields: [tax_id], references: [id], onDelete: Restrict)
  product_line_item product_line_item?
  custom_line_item  custom_line_item?

  @@index([source, source_id])
}

model product_line_item {
  id           String  @id @default(uuid())
  line_item_id String  @unique
  product_id   String  // NOT NULL — products are soft-deleted, never hard-deleted
  description  String  // snapshot of product name at time of creation
  unit_price   Decimal @db.Decimal(15, 2)
  unit_type    String  @default("item")

  line_item line_item @relation(fields: [line_item_id], references: [id], onDelete: Cascade)
  product   product   @relation(fields: [product_id],   references: [id], onDelete: Restrict)
}

model custom_line_item {
  id           String  @id @default(uuid())
  line_item_id String  @unique
  description  String
  unit_price   Decimal @db.Decimal(15, 2)
  unit_type    String  @default("item")

  line_item line_item @relation(fields: [line_item_id], references: [id], onDelete: Cascade)
}
